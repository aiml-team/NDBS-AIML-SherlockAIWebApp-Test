# ── Flask ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
SESSION_LIFETIME_DAYS=7
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
FLASK_DEBUG=false
SESSION_COOKIE_SECURE=false
# Comma-separated list of allowed CORS origins (for React dev server)
CORS_ORIGINS=http://localhost:5173

# ── Azure Blob Storage ───────────────────────────────────────────────────────
AZURE_CONNECTION_STRING=
CONTAINER_NAME=documents

# ── Azure OpenAI (Document API — summarize + classify-industry) ───────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_KEY=
OPENAI_API_VERSION=2024-02-15-preview

# ── NTTHAI Claude (VTT transcript pipeline) ──────────────────────────────────
NTTHAI_API_ID=
NTTHAI_API_SECRET=
NTTHAI_BASE_URL=https://api.ntthai.ai/v1
NTTHAI_MODEL=claude-sonnet-4-5

# ── Tavily (Internet Search enrichment) ──────────────────────────────────────
TAVILY_API_KEY=

# ── Word template path (relative to sherlock-ai/) ────────────────────────────
TEMPLATE_FILE=word_template.docx
