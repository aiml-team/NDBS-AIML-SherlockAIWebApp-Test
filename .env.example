# ── Flask ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
SESSION_LIFETIME_DAYS=7
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
FLASK_DEBUG=false
SESSION_COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:5173

# ── Azure Blob Storage ───────────────────────────────────────────────────────
AZURE_CONNECTION_STRING=
CONTAINER_NAME=documents

# ── Gmail SMTP (OTP delivery) ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Sherlock AI <your-email@gmail.com>

# ── Tavily web search ─────────────────────────────────────────────────────────
TAVILY_API_KEY=

# ── Claude Opus 4.7 via Azure AI Foundry ─────────────────────────────────────
# Document summarization, gap-fill, and industry classification
ANTHROPIC_FOUNDRY_API_KEY=
ANTHROPIC_FOUNDRY_BASE_URL=https://<your-resource>.services.ai.azure.com/anthropic/
ANTHROPIC_FOUNDRY_MODEL=claude-opus-4-7

# ── Word template ─────────────────────────────────────────────────────────────
TEMPLATE_FILE=word_template.docx
